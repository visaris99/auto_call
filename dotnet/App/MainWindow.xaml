<Window x:Class="MilestoneDialer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Milestone Dialer" Height="700" Width="1060"
        MinHeight="620" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource B.Background}"
        FontFamily="{StaticResource AppFont}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel>
        <!-- 상단 상태바 -->
        <Border DockPanel.Dock="Top" Background="{StaticResource B.Surface}"
                BorderBrush="{StaticResource B.Line}" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock x:Name="UpdateLink" FontSize="11" VerticalAlignment="Center"
                               Margin="0,0,14,0" Visibility="Collapsed">
                        <Hyperlink Click="UpdateLink_Click" Foreground="{StaticResource B.Gold}">
                            <Run x:Name="UpdateLinkRun" Text="새 버전 받기"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock x:Name="BannerText" FontSize="11" Foreground="{StaticResource B.Danger}"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock x:Name="AdbDot" Text="● ADB" FontSize="12"
                               Foreground="{StaticResource B.Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="CrmDot" Text="● CRM" FontSize="12"
                               Foreground="{StaticResource B.Muted}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="UserText" FontWeight="Bold" FontSize="13"
                           Foreground="{StaticResource B.Ink}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TodayText" Text="오늘: 발신 0 · 가입 0" FontSize="12"
                           Foreground="{StaticResource B.Gold}" VerticalAlignment="Center" Margin="14,0,0,0"/>
            </DockPanel>
        </Border>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 콜 큐 -->
            <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,6,0" Padding="10">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="4,2,4,4">
                        <Button DockPanel.Dock="Right" Content="새로고침" Style="{StaticResource GhostBtn}"
                                FontSize="11" Padding="8,4" Click="Refresh_Click"/>
                        <TextBlock FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource B.Ink}" VerticalAlignment="Center">
                            <Run Text="오늘의 콜 큐"/>
                            <Run x:Name="QueueCountRun" Text="" Foreground="{StaticResource B.Muted}"/>
                        </TextBlock>
                    </DockPanel>
                    <WrapPanel x:Name="FilterPanel" DockPanel.Dock="Top" Margin="4,0,4,6"/>
                    <ListBox x:Name="QueueList" BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="QueueList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="{Binding RowBrush}"
                                                    CornerRadius="8" Padding="10,7">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{StaticResource B.Hover}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <TextBlock Text="{Binding TimeText}" FontSize="11"
                                                   Foreground="{StaticResource B.Muted}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Border Background="{Binding BadgeBg}" CornerRadius="6" Padding="6,2">
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                                       FontWeight="Bold" Foreground="{Binding BadgeFg}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{StaticResource B.Ink}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 우측: 고객 카드 / 통화 / 결과 -->
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <Border Style="{StaticResource Card}" Padding="20,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="NameText" Text="-" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource B.Ink}"/>
                            <Border x:Name="StatusBadge" CornerRadius="6" Padding="8,3"
                                    Margin="10,8,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="StatusBadgeText" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="PhoneText" Text="-" FontSize="17"
                                   Foreground="{StaticResource B.Gold}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="LeadMemoText" FontSize="12" Foreground="{StaticResource B.Muted}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <!-- 상담 이력 (서버 API 배포 후 자동 표시) -->
                        <ItemsControl x:Name="HistoryList" Margin="0,8,0,0" MaxHeight="88">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11"
                                               Foreground="{StaticResource B.Muted}"
                                               TextTrimming="CharacterEllipsis" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20,14" Margin="0,10,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="DialBtn" Content="발신 (F1)" Style="{StaticResource SuccessBtn}"
                                    Width="170" Height="50" FontSize="15" FontWeight="Bold" Click="Dial_Click"/>
                            <Button x:Name="HangupBtn" Content="종료 (F2)" Style="{StaticResource DangerBtn}"
                                    Width="170" Height="50" FontSize="15" FontWeight="Bold"
                                    Margin="14,0,0,0" IsEnabled="False" Click="Hangup_Click"/>
                            <TextBlock x:Name="TimerText" Text="00:00" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource B.Ink}" MinWidth="80"
                                       Margin="18,0,0,0" VerticalAlignment="Center" TextAlignment="Center"/>
                            <CheckBox x:Name="AutoDialCheck" Content="연속 발신" FontSize="12"
                                      Foreground="{StaticResource B.Foreground}"
                                      Margin="16,0,0,0" VerticalAlignment="Center"
                                      ToolTip="결과 저장 후 3초 뒤 다음 리드에 자동 발신 (ESC로 중단)"
                                      Checked="AutoDial_Toggled" Unchecked="AutoDial_Toggled"/>
                        </StackPanel>
                        <!-- 수동 발신: CRM 리드와 무관한 번호 직접 발신 (기록 안 됨) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Text="수동 발신" FontSize="11" Foreground="{StaticResource B.Muted}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="ManualBox" Style="{StaticResource Input}" Width="180"
                                     MinHeight="32" FontSize="12"
                                     ToolTip="전화번호 (숫자만) — CRM에 기록되지 않습니다"/>
                            <Button x:Name="ManualDialBtn" Content="발신" Style="{StaticResource GhostBtn}"
                                    Width="72" MinHeight="32" FontSize="12" Margin="8,0,0,0"
                                    Click="ManualDial_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20,14" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="상담 결과" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource B.Ink}"/>
                        <TextBlock Text="기본" Style="{StaticResource FieldLabel}" Margin="0,8,0,4"/>
                        <UniformGrid x:Name="PrimaryResultPanel" Columns="7"/>
                        <TextBlock Text="후속/예외" Style="{StaticResource FieldLabel}" Margin="0,10,0,4"/>
                        <UniformGrid x:Name="SecondaryResultPanel" Columns="4"/>
                        <DockPanel Margin="0,12,0,0">
                            <TextBlock Text="메모" Style="{StaticResource FieldLabel}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <Button x:Name="SaveBtn" DockPanel.Dock="Right" Content="저장하고 다음 (F3)"
                                    Style="{StaticResource PrimaryBtn}" Width="176" Height="36"
                                    FontSize="13" FontWeight="Bold" Margin="8,0,0,0" Click="Save_Click"/>
                            <TextBox x:Name="CallbackBox" DockPanel.Dock="Right"
                                     Style="{StaticResource Input}" Width="72" MinHeight="34"
                                     Margin="8,0,0,0" Visibility="Collapsed"
                                     ToolTip="시간 (예: 14:30)"/>
                            <TextBox x:Name="MemoBox" Style="{StaticResource Input}" MinHeight="34"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
